{
  "name": "ib-commander",
  "version": "1.5.2",
  "description": "A TypeScript framework for building structured CLI applications",
  "keywords": [
    "cli",
    "commander",
    "typescript",
    "decorators",
    "ioc",
    "dependency-injection"
  ],
  "author": "Igor Babkin",
  "license": "MIT",
  "homepage": "https://github.com/IgorBabkin/ib-commander#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorBabkin/ib-commander.git"
  },
  "bugs": {
    "url": "https://github.com/IgorBabkin/ib-commander/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.prod.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run .test.",
    "test:integration": "vitest run .spec.",
    "test:e2e": "vitest run .e2e.",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "moq.ts": "^10.0.8",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.9",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.2",
    "ts-ioc-container": "^47.0.2",
    "commander": "^14.0.3",
    "type-fest": "^5.5.0",
    "zod": "^4.3.6"
  }
}
